# =============================================================================
# Caddyfile — reverse proxy for the game server
# =============================================================================
#
# CURRENTLY: HTTP only, using the VPS IP address.
#
# TO SWITCH TO A DOMAIN WITH AUTOMATIC HTTPS:
#   1. Point your domain's DNS A record to this VPS IP.
#   2. Replace the `:80` block below with your domain name, e.g.:
#
#        yourdomain.com {
#            reverse_proxy localhost:3000
#        }
#
#   That's it. Caddy will automatically obtain and renew a Let's Encrypt cert.
#   Remember to also update BASE_URL in your .env file.
#
# =============================================================================

:80 {
    reverse_proxy localhost:3000
}
