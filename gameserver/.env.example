# Copy this file to .env and fill in the values

# Port the server listens on internally (Caddy proxies to this)
PORT=3000

# Host to bind to (use 127.0.0.1 so only Caddy can reach it)
HOST=127.0.0.1

# Secret used to sign JWTs — generate a long random string, keep it private
JWT_SECRET=change_this_to_a_long_random_string

# Admin API key — used to protect all /api/v1/admin/* routes
ADMIN_KEY=change_this_to_another_long_random_string

# Base URL of this server — used when building audio MOTD URLs
# Use your IP for now, swap to https://yourdomain.com when you get one
BASE_URL=http://YOUR_VPS_IP:3000
